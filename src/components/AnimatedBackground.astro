---
interface Props {
  type: string;
}

const { type } = Astro.props;
---

<div class="animated-background" transition:persist="background">
  <div class="css-wave wave-1"></div>
  <div class="css-wave wave-2"></div>
  <div class="css-wave wave-3"></div>
</div>

<style>
  .animated-background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    /* Darker Gray/Black Background + Dots */
    background: 
      radial-gradient(circle, rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(135deg, #0f0f0f 0%, #000000 100%);
    background-size: 4px 4px, 100% 100%;
  }

  /* GPU-Accelerated CSS Waves */
  .css-wave {
    position: absolute;
    width: 200%;
    height: 200%;
    top: -50%;
    left: -50%;
    border-radius: 40%;
    will-change: transform;
    opacity: 0.15;
    background: linear-gradient(180deg, rgba(255,255,255,1) 0%, rgba(255,255,255,0) 100%);
    animation: rotate-wave linear infinite;
  }

  .wave-1 {
    animation-duration: 25s;
    background: linear-gradient(180deg, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0) 100%);
    top: 30%;
    left: -20%;
  }

  .wave-2 {
    animation-duration: 35s;
    background: linear-gradient(180deg, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0) 100%);
    top: 40%;
    left: 20%;
  }

  .wave-3 {
    animation-duration: 45s;
    background: linear-gradient(180deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 100%);
    top: 50%;
    left: -10%;
  }

  @keyframes rotate-wave {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }
</style>
