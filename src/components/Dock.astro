---
interface Props {
  activeWindow: string;
}

const { activeWindow } = Astro.props;

// Helper to determine if an icon is active
const isActive = (name: string) => activeWindow === name ? 'active' : '';
---

<div class="squircle-dock">
  <a href="/web/" class={`squircle-icon ${isActive('Home')}`} title="Home">
    <span>
      <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
    </span>
    Home
  </a>
  <a href="/web/projects" class={`squircle-icon ${isActive('Projects')}`} title="Projects">
    <span>
      <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
    </span>
    Projects
  </a>
  <a href="/web/credentials" class={`squircle-icon ${isActive('Credentials')}`} title="Credentials">
    <span>
      <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>
    </span>
    Creds
  </a>
  <a href="/web/archive" class={`squircle-icon ${isActive('Archive')}`} title="Archive">
    <span>
      <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="21 8 21 21 3 21 3 8"></polyline><rect x="1" y="3" width="22" height="5"></rect><line x1="10" y1="12" x2="14" y2="12"></line></svg>
    </span>
    Archive
  </a>
</div>
