---
interface Props {
  title: string;
  active?: boolean;
}

const { title, active = true } = Astro.props;
const titleClass = active ? 'title-bar active' : 'title-bar inactive';
---

<div class="os-bevel-outset" style="margin-bottom: 2rem;">
  <div class={titleClass}>
    <div class="title-text">{title}</div>
    <div class="title-bar-controls">
      <button class="os-btn title-btn" aria-label="Minimize">_</button>
      <button class="os-btn title-btn" aria-label="Maximize">◻</button>
      <button class="os-btn title-btn" aria-label="Close" style="margin-left: 2px;">X</button>
    </div>
  </div>
  <div class="window-content">
    <slot />
  </div>
</div>

<style>
  .title-btn {
    width: 16px;
    height: 14px;
    padding: 0;
    line-height: 10px;
    font-size: 10px;
    display: flex;
    justify-content: center;
    align-items: center;
  }
</style>
