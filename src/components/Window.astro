---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="os-bevel-outset" style="margin-bottom: 2rem;">
  <div class="title-bar">
    <div class="title-text">{title}</div>
    <div class="title-bar-controls">
      <button class="os-btn" aria-label="Minimize">_</button>
      <button class="os-btn" aria-label="Maximize">ㅁ</button>
      <button class="os-btn" aria-label="Close" style="margin-left: 2px;">X</button>
    </div>
  </div>
  <div class="window-content">
    <slot />
  </div>
</div>
