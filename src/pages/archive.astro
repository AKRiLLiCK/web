---
import Layout from '../layouts/Layout.astro';
import Screen from '../components/Screen.astro';
---

<Layout title="Archive">
  <Screen>
    <div class="banner">
      <h1>Archive</h1>
    </div>
    <div class="page-content">
      <div class="ui-card">
        <img src="https://placehold.co/800x200/151515/444444?text=Archive+Banner" alt="Archive Banner" class="ui-card-banner" />
        <h2>The Architecture of Computing Systems</h2>
        <span class="ui-badge">Technical Essay</span>
        <p>An exploratory technical essay detailing the structural paradigms of operating systems and their historical divergence.</p>
        <a href="#" class="ui-button">Read Essay</a>
      </div>
    </div>
  </Screen>
</Layout>
