---
import Layout from '../../layouts/Layout.astro';
import Screen from '../../components/Screen.astro';
import webring from '../../data/webring.json';

const widgetSnippet = `<div style="background:#151515; color:#fff; border:1px solid #333; padding:10px; font-family:monospace; text-align:center; max-width:300px;">
  <div style="margin-bottom:8px; font-weight:bold;">OTA Webring</div>
  <a href="https://akrillick.github.io/web/webring/nav?action=prev&current=YOUR_ID" style="color:#fff; text-decoration:none;">[ &larr; Prev ]</a>
  <a href="https://akrillick.github.io/web/webring/" style="color:#fff; text-decoration:none; margin:0 10px;">[ Directory ]</a>
  <a href="https://akrillick.github.io/web/webring/nav?action=next&current=YOUR_ID" style="color:#fff; text-decoration:none;">[ Next &rarr; ]</a>
</div>`;
---

<Layout title="OTA Webring" wide={true}>
  <Screen>
    <div class="banner">
      <h1>OTA Webring</h1>
      <p class="description">A decentralized network of systems complying with the Open To All declaration.</p>
    </div>
    
    <div class="page-content">
      <h2>Webring Nodes</h2>
      <div class="webring-grid">
        {webring.map((member) => (
          <div class="member-card">
            <h3 class="member-title"><a href={member.url} target="_blank" rel="noopener noreferrer">{member.name}</a></h3>
            <p class="member-desc">{member.description}</p>
            <span class="member-id">ID: {member.id}</span>
          </div>
        ))}
      </div>

      <div class="widget-section">
        <h2>Join the Network</h2>
        <p>To join the OTA webring, submit a pull request adding your site to our registry, and embed the following widget on your site. Replace <code>YOUR_ID</code> with your assigned ID.</p>
        <pre class="snippet"><code>{widgetSnippet}</code></pre>
      </div>
    </div>

    <style>
      .description {
        color: #888;
        text-align: center;
        max-width: 600px;
        margin: 0.5rem auto 0 auto;
      }
      .page-content {
        padding: 2rem;
        color: var(--text-main);
      }
      .page-content h2 {
        margin-top: 0;
        margin-bottom: 1rem;
        border-bottom: 1px solid #333;
        padding-bottom: 0.5rem;
      }
      .webring-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 1.5rem;
        margin-bottom: 3rem;
      }
      .member-card {
        background: #111;
        border: 1px solid #333;
        padding: 1.5rem;
        border-radius: 4px;
        display: flex;
        flex-direction: column;
      }
      .member-title {
        margin: 0 0 0.5rem 0;
        font-size: 1.1rem;
      }
      .member-title a {
        color: #fff;
        text-decoration: none;
      }
      .member-title a:hover {
        text-decoration: underline;
      }
      .member-desc {
        color: #aaa;
        font-size: 0.9rem;
        margin: 0 0 1rem 0;
        flex-grow: 1;
      }
      .member-id {
        font-family: monospace;
        font-size: 0.8rem;
        color: #555;
        background: #000;
        padding: 2px 6px;
        border-radius: 3px;
        align-self: flex-start;
      }
      .widget-section {
        background: #151515;
        border: 1px solid #333;
        padding: 1.5rem;
        border-radius: 4px;
      }
      .snippet {
        background: #000;
        padding: 1rem;
        overflow-x: auto;
        border: 1px solid #222;
        border-radius: 4px;
        color: #0f0;
      }
    </style>
  </Screen>
</Layout>
