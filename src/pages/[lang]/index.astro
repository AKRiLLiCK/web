---
import Layout from '../../layouts/Layout.astro';
import Window from '../../components/Window.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } }
  ];
}

const { lang } = Astro.params;

const t = {
  en: {
    title: 'Home',
    nav_home: 'Home',
    nav_projects: 'Projects',
    nav_credentials: 'Credentials',
    nav_archive: 'Archive',
    identityTitle: 'Identity',
    identityText: 'Computer Engineering Student & Polymath',
    stackTitle: 'Tech Stack',
    stackText: 'Languages: Rust, C\nSystems: Linux (Arch/Debian/Kali/Nix), Windows\nEngines: Godot\nHardware: Arduino\nDomain: Applied Physics',
    linksTitle: 'Links'
  },
  es: {
    title: 'Inicio',
    nav_home: 'Inicio',
    nav_projects: 'Proyectos',
    nav_credentials: 'Credenciales',
    nav_archive: 'Archivo',
    identityTitle: 'Identidad',
    identityText: 'Estudiante de Ingeniería Informática y Polímata',
    stackTitle: 'Stack Tecnológico',
    stackText: 'Lenguajes: Rust, C\nSistemas: Linux (Arch/Debian/Kali/Nix), Windows\nMotores: Godot\nHardware: Arduino\nDominio: Física Aplicada',
    linksTitle: 'Enlaces'
  }
}[lang as 'en' | 'es'];
---

<Layout title={t.title} lang={lang}>
  <header>
    <nav class="os-bevel-outset" style="padding: 0.5rem; margin-bottom: 2rem; display: flex; gap: 1rem; background-color: var(--bg-window);">
      <a href={`/${lang}/`}>{t.nav_home}</a>
      <a href={`/${lang}/projects`}>{t.nav_projects}</a>
      <a href={`/${lang}/credentials`}>{t.nav_credentials}</a>
      <a href={`/${lang}/archive`}>{t.nav_archive}</a>
    </nav>
  </header>

  <Window title={t.identityTitle} active={false}>
    <h1 style="text-align: center; margin: 0 0 1rem 0;">Acrilic</h1>
    <p style="text-align: center; margin-top: 0;">{t.identityText}</p>
  </Window>

  <Window title={t.stackTitle} active={true}>
    <pre class="os-bevel-inset" style="padding: 0.5rem; margin-bottom: 1rem;">{t.stackText}</pre>
    <img src="https://skillicons.dev/icons?i=rust,c,linux,godot,arduino" alt="Tech Stack Icons" style="max-width: 100%; height: auto;" />
  </Window>

  <Window title={t.linksTitle} active={false}>
    <ul>
      <li><a href="#">GitHub</a></li>
      <li><a href="#">YouTube</a></li>
      <li><a href="#">Ko-Fi</a></li>
      <li><a href="#">ORCID</a></li>
    </ul>
  </Window>
</Layout>
