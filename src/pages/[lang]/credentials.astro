---
import Layout from '../../layouts/Layout.astro';
import Window from '../../components/Window.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } }
  ];
}

const { lang } = Astro.params;

const t = {
  en: {
    title: 'C:\\CtrlPanel',
    controlTitle: 'Control Panel - Credentials',
    nav_desktop: 'Desktop',
    nav_work: 'Explorer',
    nav_credentials: 'Ctrl Panel',
    nav_library: 'Notepad',
    categories: [
      { name: 'Computer Engineering BSc', status: 'Valid' },
      { name: 'SysAdmin Certifications', status: 'Valid' },
      { name: 'Identity Verification Key', status: 'Active' }
    ]
  },
  es: {
    title: 'C:\\PanelCtrl',
    controlTitle: 'Panel de Control - Credenciales',
    nav_desktop: 'Escritorio',
    nav_work: 'Explorador',
    nav_credentials: 'Panel Ctrl',
    nav_library: 'Bloc Notas',
    categories: [
      { name: 'Grado en Ingeniería Informática', status: 'Válido' },
      { name: 'Certificaciones SysAdmin', status: 'Válido' },
      { name: 'Clave de Verificación de Identidad', status: 'Activo' }
    ]
  }
}[lang as 'en' | 'es'];
---

<Layout title={t.title} lang={lang}>
  <header>
    <h1>{t.title}</h1>
    <nav class="os-bevel-outset" style="padding: 0.5rem; margin-bottom: 2rem; display: flex; gap: 1rem;">
      <a href={`/${lang}/`}>{t.nav_desktop}</a>
      <a href={`/${lang}/work`}>{t.nav_work}</a>
      <a href={`/${lang}/credentials`}>{t.nav_credentials}</a>
      <a href={`/${lang}/library`}>{t.nav_library}</a>
    </nav>
  </header>

  <Window title={t.controlTitle}>
    <ul style="list-style-type: square; padding-left: 20px;">
      {t.categories.map(cat => (
        <li style="margin-bottom: 10px;">
          <strong>{cat.name}</strong> - [{cat.status}]
        </li>
      ))}
    </ul>
  </Window>
</Layout>
