---
import Layout from '../../layouts/Layout.astro';
import Window from '../../components/Window.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } }
  ];
}

const { lang } = Astro.params;

const t = {
  en: {
    title: 'Projects',
    explorerTitle: 'Portfolio',
    nav_home: 'Home',
    nav_projects: 'Projects',
    nav_credentials: 'Credentials',
    nav_archive: 'Archive',
    items: [
      { icon: '📁', name: 'Yutila', desc: 'Software, Games, and Hardware' }
    ]
  },
  es: {
    title: 'Proyectos',
    explorerTitle: 'Portafolio',
    nav_home: 'Inicio',
    nav_projects: 'Proyectos',
    nav_credentials: 'Credenciales',
    nav_archive: 'Archivo',
    items: [
      { icon: '📁', name: 'Yutila', desc: 'Software, Juegos y Hardware' }
    ]
  }
}[lang as 'en' | 'es'];
---

<Layout title={t.title} lang={lang}>
  <header>
    <nav class="os-bevel-outset" style="padding: 0.5rem; margin-bottom: 2rem; display: flex; gap: 1rem; background-color: var(--bg-window);">
      <a href={`/${lang}/`}>{t.nav_home}</a>
      <a href={`/${lang}/projects`}>{t.nav_projects}</a>
      <a href={`/${lang}/credentials`}>{t.nav_credentials}</a>
      <a href={`/${lang}/archive`}>{t.nav_archive}</a>
    </nav>
  </header>

  <Window title={t.explorerTitle} active={true}>
    <div class="grid-icons os-bevel-inset" style="padding: 1rem; min-height: 200px;">
      {t.items.map(folder => (
        <div class="icon-item" style="display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.5rem; padding: 0.5rem;">
          <div class="icon-item-graphic" style="font-size: 2.5rem;">{folder.icon}</div>
          <strong>{folder.name}</strong>
          <span style="font-size: 0.8rem; color: #c0c0c0;">{folder.desc}</span>
        </div>
      ))}
    </div>
  </Window>
</Layout>
