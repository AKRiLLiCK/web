---
import Layout from '../../layouts/Layout.astro';
import Window from '../../components/Window.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } }
  ];
}

const { lang } = Astro.params;

const t = {
  en: {
    title: 'C:\\Documents',
    notebookTitle: 'Notepad - Library',
    nav_desktop: 'Desktop',
    nav_work: 'Explorer',
    nav_credentials: 'Ctrl Panel',
    nav_library: 'Notepad',
    intro: 'Directory structure for books read, philosophical inquiries, and technical essays.',
    files: [
      { name: 'On_Logic.txt', type: 'TXT File' },
      { name: 'Architecture_Patterns.md', type: 'MDX Document' },
      { name: 'Reading_List_2026.log', type: 'Log File' }
    ]
  },
  es: {
    title: 'C:\\Documentos',
    notebookTitle: 'Bloc_de_Notas - Biblioteca',
    nav_desktop: 'Escritorio',
    nav_work: 'Explorador',
    nav_credentials: 'Panel Ctrl',
    nav_library: 'Bloc Notas',
    intro: 'Estructura de directorio para libros leídos, investigaciones filosóficas y ensayos técnicos.',
    files: [
      { name: 'Sobre_Lógica.txt', type: 'Archivo TXT' },
      { name: 'Patrones_Arquitectura.md', type: 'Documento MDX' },
      { name: 'Lista_Lectura_2026.log', type: 'Archivo Log' }
    ]
  }
}[lang as 'en' | 'es'];
---

<Layout title={t.title} lang={lang}>
  <header>
    <h1>{t.title}</h1>
    <nav class="os-bevel-outset" style="padding: 0.5rem; margin-bottom: 2rem; display: flex; gap: 1rem;">
      <a href={`/${lang}/`}>{t.nav_desktop}</a>
      <a href={`/${lang}/work`}>{t.nav_work}</a>
      <a href={`/${lang}/credentials`}>{t.nav_credentials}</a>
      <a href={`/${lang}/library`}>{t.nav_library}</a>
    </nav>
  </header>

  <Window title={t.notebookTitle}>
    <p style="font-family: 'Courier New', Courier, monospace; margin-bottom: 1rem;">
      {t.intro}
    </p>
    <div style="background-color: #ffffff; color: #000000; padding: 10px; min-height: 200px; font-family: 'Courier New', Courier, monospace;" class="os-bevel-inset">
      {t.files.map(f => (
        <div style="display: flex; gap: 1rem; margin-bottom: 5px;">
          <span>📄</span>
          <span style="flex-grow: 1;">{f.name}</span>
          <span style="color: #808080;">{f.type}</span>
        </div>
      ))}
    </div>
  </Window>
</Layout>
