---
import Layout from '../layouts/Layout.astro';
import Screen from '../components/Screen.astro';
---

<Layout title="Home">
  <Screen>
    <div style="text-align: center; margin-bottom: 2rem;">
      <h1 style="font-size: 2rem; margin-bottom: 0.5rem; letter-spacing: 2px;">ACRILIC</h1>
      <p style="color: var(--text-muted); font-size: 0.9rem; margin: 0.25rem 0;">Computer Engineering Student</p>
      <p style="color: var(--text-muted); font-size: 0.9rem; margin: 0.25rem 0;">Polymath</p>
      <p style="color: var(--text-muted); font-size: 0.9rem; margin: 0.25rem 0;">Founder of Yutila</p>
    </div>

    <hr />

    <div style="text-align: center; margin-top: 2rem;">
      <h2 style="font-size: 1.2rem; margin-bottom: 1rem;">Tech Stack</h2>
      <img src="https://skillicons.dev/icons?i=rust,c,linux,godot,arduino,js" width="310" height="48" alt="Tech Stack Icons" style="image-rendering: auto;" />
    </div>
  </Screen>
</Layout>
