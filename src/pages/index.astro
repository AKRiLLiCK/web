---
import Layout from "../layouts/Layout.astro";
import Screen from "../components/Screen.astro";

const techStack = [
    { name: "Rust", icon: "rust" },
    { name: "C", icon: "c" },
    { name: "Java", icon: "java" },
    { name: "Python", icon: "python" },
    { name: "Bash", icon: "bash" },
    { name: "PowerShell", icon: "powershell" },
    { name: "Linux", icon: "linux" },
    { name: "Arch Linux", icon: "arch" },
    { name: "Debian", icon: "debian" },
    { name: "Kali Linux", icon: "kali" },
    { name: "NixOS", icon: "nix" },
    { name: "Windows", icon: "windows" },
    { name: "HTML", icon: "html" },
    { name: "CSS", icon: "css" },
    { name: "Astro", icon: "astro" },
    { name: "Arduino", icon: "arduino" },
    { name: "Godot", icon: "godot" },
    { name: "Git", icon: "git" },
    { name: "GitHub", icon: "github" },
    { name: "Docker", icon: "docker" },
    { name: "VSCode", icon: "vscode" },
    { name: "NeoVim", icon: "neovim" },
    { name: "IntelliJ IDEA", icon: "idea" },
    { name: "Obsidian", icon: "obsidian" },
    { name: "Discord", icon: "discord" },
];

const totalSlots = 30; // 5 rows of 6
---

<Layout title="Home">
    <Screen>
        <div class="banner">
            <h1>ACRILIC</h1>
        </div>
        <div class="page-content">
            <div style="text-align: center; margin-bottom: 2rem;">
                <a
                    href="https://en.pronouns.page/@Acrilic"
                    target="_blank"
                    class="pastel-card"
                    style="text-align: left; margin: 0 auto 1.5rem auto; max-width: 600px;"
                >
                    <h2>
                        <img
                            src="https://en.pronouns.page/favicon.ico"
                            width="24"
                            height="24"
                            alt="Pronouns.page"
                            style="border-radius: 4px;"
                        />
                        Acrilic
                    </h2>
                    <div style="margin-bottom: 0.8rem;">
                        <span class="pastel-badge pink">He/Him</span>
                        <span class="pastel-badge blue">🇪🇸 ES (Native)</span>
                        <span class="pastel-badge green">🇺🇸 EN (C1)</span>
                    </div>
                    <p>
                        <strong>Computer Engineering Student</strong>, founder
                        of Yutila, <strong>polymath</strong>, and
                        multidisciplinary creator — exploring the full depth of
                        the computing spectrum.
                    </p>
                </a>

                <div style="margin-top: 1rem;">
                    <a
                        href="https://youtube.com/@AKRiLLiCK"
                        class="software-badge"
                    >
                        <img
                            src="https://img.shields.io/badge/YouTube-FF0000?style=for-the-badge&logo=youtube&logoColor=white"
                            alt="YouTube"
                            width="106"
                            height="28"
                        />
                    </a>
                    <a href="https://ko-fi.com/acrilic" class="software-badge">
                        <img
                            src="https://img.shields.io/badge/Ko--fi-F16061?style=for-the-badge&logo=ko-fi&logoColor=white"
                            alt="Ko-Fi"
                            width="82"
                            height="28"
                        />
                    </a>
                    <a
                        href="https://orcid.org/0009-0003-6052-2564"
                        class="software-badge"
                    >
                        <img
                            src="https://img.shields.io/badge/ORCID-A6CE39?style=for-the-badge&logo=orcid&logoColor=white"
                            alt="ORCID"
                            width="87"
                            height="28"
                        />
                    </a>
                </div>
            </div>

            <hr />

            <div class="identity-section">
                <h2 style="display: flex; align-items: center; gap: 0.5rem;">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"
                        ></path><circle cx="12" cy="7" r="4"></circle></svg
                    > The Identity
                </h2>
                <p>
                    A creator bridging technical rigor and artistic expression.
                    I operate through a faceless identity to prioritize ideas,
                    logic, and craft. Currently building Yutila, a startup
                    spanning software, games, and hardware.
                </p>
                <p>
                    My work lives at the intersection of hard engineering,
                    philosophy, and design. I explore the full computing
                    spectrum—from hardware physics to software logic—to build
                    systems that foster digital autonomy and critical thinking.
                </p>
            </div>

            <hr />

            <div class="scope-section">
                <h2 style="display: flex; align-items: center; gap: 0.5rem;">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><circle cx="12" cy="12" r="10"></circle><line
                            x1="22"
                            y1="12"
                            x2="18"
                            y2="12"></line><line x1="6" y1="12" x2="2" y2="12"
                        ></line><line x1="12" y1="6" x2="12" y2="2"></line><line
                            x1="12"
                            y1="22"
                            x2="12"
                            y2="18"></line></svg
                    > The Scope
                </h2>

                <h3 style="display: flex; align-items: center; gap: 0.5rem;">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><polyline points="4 17 10 11 4 5"></polyline><line
                            x1="12"
                            y1="19"
                            x2="20"
                            y2="19"></line></svg
                    > Systems & Logic
                </h3>
                <ul>
                    <li>
                        <strong>Engineering Reality:</strong> Applied physics, hardware
                        tinkering and embedded logic.
                    </li>
                    <li>
                        <strong>The Deep Stack:</strong> Linux, containerization &
                        virtualization and programming.
                    </li>
                    <li>
                        <strong>Software Engineering:</strong> Python, Java, Bash,
                        modern web (Astro) and secure CI/CD.
                    </li>
                    <li>
                        <strong>Cybersecurity:</strong> Ethical hacking, digital defense
                        and supply-chain validation.
                    </li>
                </ul>

                <h3 style="display: flex; align-items: center; gap: 0.5rem;">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path
                            d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3Z"
                        ></path></svg
                    > Creative & Narrative
                </h3>
                <ul>
                    <li><strong>Game Dev:</strong> Godot.</li>
                    <li><strong>Design:</strong> UI/UX architecture & more.</li>
                    <li>
                        <strong>Media:</strong> Philosophy, writing and YouTube.
                    </li>
                    <li><strong>Music:</strong> Composition & production.</li>
                </ul>
            </div>

            <hr />

            <div class="stack-section">
                <h2 style="display: flex; align-items: center; gap: 0.5rem;">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><circle cx="12" cy="12" r="3"></circle><path
                            d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"
                        ></path></svg
                    > Working Ecosystem
                </h2>
                <p>
                    Whether I am structuring philosophical essays, producing
                    audiovisual content, developing in Godot, or maintaining
                    Yutila's security infrastructure (NixOS/Docker/Wazuh), my
                    approach remains the same: technical rigor, privacy by
                    design, and creative purpose.
                </p>
                <p>
                    <strong>Operational Philosophy:</strong> Build to learn. Performance
                    without compromising privacy.
                </p>
            </div>

            <details class="ds-toggle">
                <summary
                    ><svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path
                            d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"
                        ></path></svg
                    > The Archive (OTA)</summary
                >
                <div class="ds-toggle-content">
                    <p>
                        Beyond software and hardware, I maintain an open-access
                        library of technical documentation, philosophical
                        essays, and research papers under the <strong
                            >Open To All (OTA)</strong
                        > public license.
                    </p>
                    <div style="text-align: center; margin-top: 1.5rem;">
                        <a
                            href="/web/archive"
                            class="ui-button"
                            style="padding: 0.75rem 1.5rem; font-size: 1.1rem;"
                            >Access the Arcadia Archive</a
                        >
                    </div>
                </div>
            </details>

            <details class="ds-toggle">
                <summary
                    ><svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"
                        ></path><circle cx="9" cy="7" r="4"></circle><path
                            d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path
                            d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg
                    > Network & Friends</summary
                >
                <div class="ds-toggle-content">
                    <p>A collection of interesting nodes in my network.</p>
                    <ul style="list-style-type: none; padding-left: 0;">
                        <li
                            style="margin-bottom: 0.8rem; display: flex; align-items: center; gap: 0.8rem;"
                        >
                            <img
                                src="/web/friends/spider-kyle.png"
                                alt="Friend 1"
                                style="width: 32px; height: 32px; border-radius: 50%; border: 1px solid #444; object-fit: cover; background: #222;"
                                onerror="this.src='data:image/svg+xml,%3Csvg xmlns=\\'http://www.w3.org/2000/svg\\' viewBox=\\'0 0 24 24\\' fill=\\'none\\' stroke=\\'%23666\\' stroke-width=\\'2\\' stroke-linecap=\\'round\\' stroke-linejoin=\\'round\\'%3E%3Cpath d=\\'M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2\\'%3E%3C/path%3E%3Ccircle cx=\\'12\\' cy=\\'7\\' r=\\'4\\'%3E%3C/circle%3E%3C/svg%3E'"
                            />
                            <div>
                                <a
                                    href="https://spider-kyle.neocities.org/"
                                    style="font-weight: bold; color: var(--text-main);"
                                    >Spider-Kyle</a
                                > -
                                <span style="color: var(--text-muted);"
                                    >Student, software engineer and gamedev</span
                                >
                            </div>
                        </li>
                    </ul>
                </div>
            </details>

            <hr />

            <div
                style="text-align: center; margin-top: 2rem; overflow-x: auto; scroll-behavior: smooth; -webkit-overflow-scrolling: touch;"
            >
                <h2
                    style="font-size: 1.2rem; margin-bottom: 1rem; border: none;"
                >
                    Tech Stack
                </h2>
                <div
                    class="home-menu-grid"
                    style="max-width: 600px; margin: 0 auto;"
                >
                    {
                        Array.from({ length: totalSlots }).map((_, i) => {
                            const tech = techStack[i];
                            return tech ? (
                                <div class="home-menu-slot" title={tech.name}>
                                    <div class="software-badge">
                                        <img
                                            src={`https://skillicons.dev/icons?i=${tech.icon}`}
                                            width="48"
                                            height="48"
                                            alt={tech.name}
                                            loading="lazy"
                                        />
                                    </div>
                                </div>
                            ) : (
                                <div class="home-menu-slot">
                                    <div class="empty-slot" />
                                </div>
                            );
                        })
                    }
                </div>
            </div>
        </div>
    </Screen>
</Layout>
