---
import Layout from '../layouts/Layout.astro';
import Window from '../components/Window.astro';
---

<Layout title="Home">
  <header>
    <nav class="os-bevel-outset" style="padding: 0.5rem; margin-bottom: 2rem; display: flex; gap: 1rem;">
      <a href="/web/">Home</a>
      <a href="/web/projects">Projects</a>
      <a href="/web/credentials">Credentials</a>
      <a href="/web/archive">Archive</a>
    </nav>
  </header>

  <Window title="Identity" active={false}>
    <h1 style="text-align: center; margin: 0 0 1rem 0;">Acrilic</h1>
    <p style="text-align: center; margin-top: 0;">Computer Engineering Student & Polymath</p>
  </Window>

  <Window title="Tech Stack" active={true}>
    <pre class="os-bevel-inset" style="padding: 0.5rem; margin-bottom: 1rem;">Languages: Rust, C
Systems: Linux (Arch/Debian/Kali/Nix), Windows
Engines: Godot
Hardware: Arduino
Domain: Applied Physics</pre>
  </Window>

  <Window title="Links" active={false}>
    <ul>
      <li><a href="#">GitHub</a></li>
      <li><a href="#">YouTube</a></li>
      <li><a href="#">Ko-Fi</a></li>
      <li><a href="#">ORCID</a></li>
    </ul>
  </Window>
</Layout>
