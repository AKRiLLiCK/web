---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Screen from '../../components/Screen.astro';

export async function getStaticPaths() {
  const archiveEntries = await getCollection('archive');
  return archiveEntries.map(entry => ({
    params: { slug: entry.id }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, author, publishDate, docType, downloadUrl, coverImage, isbn } = entry.data;

const formattedDate = publishDate.toISOString().split('T')[0];
---

<Layout title={title} wide={true}>
  <Screen>
    <div class="banner">
      <h1>Archive</h1>
    </div>
    <div class="page-content preview-content">
      
      <div class="split-view">
        <div class="cover-column">
          <div class="cover-container">
            <Image 
              src={coverImage} 
              alt={`Cover of ${title}`} 
              width={300} 
              height={420} 
              class="detail-cover" 
            />
          </div>
        </div>
        
        <div class="metadata-column">
          <h2 class="detail-title">{title}</h2>
          <div class="metadata-table">
            <div class="meta-row">
              <span class="meta-label">Author</span>
              <span class="meta-value">{author}</span>
            </div>
            <div class="meta-row">
              <span class="meta-label">Published</span>
              <span class="meta-value">{formattedDate}</span>
            </div>
            <div class="meta-row">
              <span class="meta-label">Type</span>
              <span class="meta-value">
                <span class={`tag tag-${docType.toLowerCase()}`}>{docType}</span>
              </span>
            </div>
            {isbn && (
              <div class="meta-row">
                <span class="meta-label">ISBN</span>
                <span class="meta-value">{isbn}</span>
              </div>
            )}
          </div>
          <div class="download-section">
            <a href={downloadUrl || '#'} class="squircle-btn download-btn">
              Access
            </a>
          </div>
        </div>
      </div>
      
      <hr class="separator" />

      <div class="markdown-body">
        <Content />
      </div>
    </div>

    <style>
      .preview-content {
        display: flex;
        flex-direction: column;
      }
      
      .split-view {
        display: grid;
        grid-template-columns: minmax(180px, 1fr) 2fr;
        gap: 2rem;
        margin-bottom: 1.5rem;
      }

      @media (max-width: 600px) {
        .split-view {
          grid-template-columns: 1fr;
        }
      }

      .cover-container {
        border: 4px solid #222;
        border-radius: 4px;
        background: #000;
        box-shadow: 0 4px 8px rgba(0,0,0,0.8), inset 0 0 5px rgba(255,255,255,0.1);
        overflow: hidden;
      }

      .detail-cover {
        width: 100%;
        height: auto;
        display: block;
      }

      .metadata-column {
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
      }

      .detail-title {
        font-size: 1.6rem;
        color: var(--text-main);
        margin-bottom: 1rem;
        line-height: 1.2;
        border-bottom: 2px solid #222;
        padding-bottom: 0.5rem;
      }

      .metadata-table {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
        background: rgba(0,0,0,0.4);
        border: 1px solid #333;
        border-radius: 6px;
        padding: 1rem;
        box-shadow: inset 0 0 10px rgba(0,0,0,0.6);
      }

      .meta-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px dashed #333;
        padding-bottom: 0.4rem;
      }

      .meta-row:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }

      .meta-label {
        color: #777;
        font-size: 0.85rem;
        text-transform: uppercase;
        font-weight: bold;
        letter-spacing: 1px;
      }

      .meta-value {
        color: var(--text-main);
        font-size: 0.95rem;
        text-align: right;
      }

      .separator {
        border-color: #333;
        margin: 2rem 0;
      }

      .tag {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 0.85rem;
        font-family: monospace;
        border: 1px solid;
      }
      .tag-book { color: #bae1ff; border-color: rgba(186, 225, 255, 0.3); background: rgba(186, 225, 255, 0.1); }
      .tag-paper { color: #ffffba; border-color: rgba(255, 255, 186, 0.3); background: rgba(255, 255, 186, 0.1); }
      .tag-essay { color: #baffc9; border-color: rgba(186, 255, 201, 0.3); background: rgba(186, 255, 201, 0.1); }
      .tag-manual { color: #ffdfba; border-color: rgba(255, 223, 186, 0.3); background: rgba(255, 223, 186, 0.1); }
      .tag-devlog { color: #e0b0ff; border-color: rgba(224, 176, 255, 0.3); background: rgba(224, 176, 255, 0.1); }

      .markdown-body {
        color: var(--text-muted);
        line-height: 1.7;
        font-size: 0.95rem;
        flex-grow: 1;
      }
      
      .markdown-body p {
        margin-bottom: 1.2rem;
      }

      .download-section {
        margin-top: 1.5rem;
        display: flex;
        justify-content: flex-end;
      }

      .squircle-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 12px 28px;
        background: linear-gradient(180deg, #3a3a3a 0%, #111 100%);
        border: 2px solid #000;
        border-radius: 12px;
        box-shadow: inset 0 2px 4px rgba(255,255,255,0.1), 0 4px 6px rgba(0,0,0,0.5), 0 0 0 1px #444;
        color: var(--text-main);
        font-weight: bold;
        text-transform: uppercase;
        font-size: 0.95rem;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.1s;
        text-decoration: none;
      }

      .squircle-btn:active {
        box-shadow: inset 0 4px 8px rgba(0,0,0,0.8), 0 0 0 1px #222;
        background: linear-gradient(180deg, #111 0%, #2a2a2a 100%);
        transform: translateY(2px);
      }
    </style>
  </Screen>
</Layout>
