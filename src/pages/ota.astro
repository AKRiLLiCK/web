    <style>
      .markdown-body {
        color: var(--text-muted);
        line-height: 1.7;
        font-size: 0.95rem;
      }
      .markdown-body h2 {
        color: #fff;
        font-size: 1.5rem;
      }
      .markdown-body h3 {
        color: #eee;
        font-size: 1.2rem;
        margin-top: 2rem;
        margin-bottom: 1rem;
      }
      .download-link {
        background: #222;
        color: var(--text-main);
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 0.85rem;
        text-decoration: none;
        font-weight: bold;
        border: 1px solid #333;
        transition: all 0.2s ease;
      }
      .download-link:hover {
        background: #333;
        border-color: #555;
      }
      .markdown-body h4 {
        color: #ddd;
        font-size: 1.05rem;
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
      }
      .markdown-body p {
        margin-bottom: 1.2rem;
      }
      .markdown-body ul {
        padding-left: 1.5rem;
        margin-bottom: 1.5rem;
      }
      .markdown-body ul li {
        margin-bottom: 0.5rem;
      }
      .markdown-body strong {
        color: var(--text-main);
      }
      .markdown-body code {
        background: #111;
        padding: 2px 4px;
        border-radius: 4px;
        font-family: monospace;
        border: 1px solid #333;
      }
    </style>
  </Screen>
</Layout>
