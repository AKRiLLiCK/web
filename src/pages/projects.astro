---
import Layout from '../layouts/Layout.astro';
import Screen from '../components/Screen.astro';

const basePath = import.meta.env.BASE_URL;

const frameworks = [
  {
    image: `${basePath}projects/camelot-banner.png`,
    alt: "Camelot Banner",
    title: "Camelot",
    badges: ["C Framework", "License: MPL-2.0"],
    description: "An enterprise-grade C framework prioritizing long-term reliability, cross-platform interoperability, and transaction stability for mission-critical environments.",
    link: "https://github.com/yutila-org/camelot"
  }
];

const tools: { image: string; alt: string; title: string; badges: string[]; description: string; link: string; }[] = [];
---

<Layout title="Projects">
  <Screen>
    <div class="banner">
      <h1>Projects</h1>
    </div>
    <div class="page-content">
      <div class="projects-nav" style="margin-bottom: 2rem; text-align: center;">
        <a href="#frameworks" class="ui-button" style="margin-right: 1rem;">Frameworks ({frameworks.length})</a>
        <a href="#tools" class="ui-button">Tools & Utilities ({tools.length})</a>
      </div>

      <h2 id="frameworks" style="margin-top: 0; padding-top: 1rem;">Frameworks ({frameworks.length})</h2>
      <hr style="margin-bottom: 1.5rem;" />
      {frameworks.length > 0 ? (
        <div class="gallery-grid">
          {frameworks.map(fw => (
            <div class="ui-card">
              <img src={fw.image} alt={fw.alt} class="ui-card-banner" />
              <h2>{fw.title}</h2>
              {fw.badges.map(b => <span class="ui-badge" style="margin-right: 4px;">{b}</span>)}
              <p>{fw.description}</p>
              <a href={fw.link} target="_blank" class="ui-button">View Repository</a>
            </div>
          ))}
        </div>
      ) : (
        <p style="text-align: center; color: #888; font-style: italic;">No frameworks listed yet.</p>
      )}

      <h2 id="tools" style="padding-top: 1rem; margin-top: 2rem;">Tools & Utilities ({tools.length})</h2>
      <hr style="margin-bottom: 1.5rem;" />
      {tools.length > 0 ? (
        <div class="gallery-grid">
          {tools.map(tool => (
            <div class="ui-card">
              <img src={tool.image} alt={tool.alt} class="ui-card-banner" />
              <h2>{tool.title}</h2>
              {tool.badges.map(b => <span class="ui-badge" style="margin-right: 4px;">{b}</span>)}
              <p>{tool.description}</p>
              <a href={tool.link} target="_blank" class="ui-button">View Repository</a>
            </div>
          ))}
        </div>
      ) : (
        <p style="text-align: center; color: #888; font-style: italic;">More tools coming soon.</p>
      )}
    </div>
  </Screen>
</Layout>
