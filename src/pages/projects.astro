---
import Layout from '../layouts/Layout.astro';
import Screen from '../components/Screen.astro';
---

<Layout title="Projects">
  <Screen>
    <div class="banner">
      <h1>Projects</h1>
    </div>
    <div class="page-content">
      <div class="ui-card">
        <img src="https://placehold.co/800x200/151515/444444?text=Project+Banner" alt="Project Banner" class="ui-card-banner" />
        <h2>Yutila</h2>
        <span class="ui-badge">Software, Games, and Hardware</span>
        <p>A comprehensive organization scope dedicated to creating unified tools, foundational game engines, and low-level hardware abstractions.</p>
        <a href="#" class="ui-button">View Repository</a>
      </div>
    </div>
  </Screen>
</Layout>
