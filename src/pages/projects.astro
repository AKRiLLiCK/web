---
import Layout from '../layouts/Layout.astro';
import Window from '../components/Window.astro';
---

<Layout title="Projects">
  <header>
    <nav class="os-bevel-outset" style="padding: 0.5rem; margin-bottom: 2rem; display: flex; gap: 1rem;">
      <a href="/web/">Home</a>
      <a href="/web/projects">Projects</a>
      <a href="/web/credentials">Credentials</a>
      <a href="/web/archive">Archive</a>
    </nav>
  </header>

  <Window title="Portfolio" active={true}>
    <div class="grid-icons os-bevel-inset" style="padding: 1rem; min-height: 200px;">
      <div class="icon-item" style="display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.5rem; padding: 0.5rem;">
        <div class="icon-item-graphic" style="font-size: 2.5rem;">📁</div>
        <strong>Yutila</strong>
        <span style="font-size: 0.8rem; color: #c0c0c0;">Software, Games, and Hardware</span>
      </div>
    </div>
  </Window>
</Layout>
