---
import Layout from '../layouts/Layout.astro';
import Screen from '../components/Screen.astro';
---

<Layout title="Projects">
  <Screen>
    <h1 style="font-size: 1.5rem; border-bottom: 1px solid #333; padding-bottom: 0.5rem; margin-bottom: 1.5rem;">Projects</h1>
    
    <div style="background: rgba(255,255,255,0.05); border: 1px solid #333; border-radius: 8px; padding: 1rem;">
      <h2 style="font-size: 1.2rem; margin-bottom: 0.25rem;">Yutila</h2>
      <span style="display: inline-block; background: #222; color: #aaa; font-size: 0.7rem; padding: 2px 6px; border-radius: 4px; margin-bottom: 1rem;">Software, Games, and Hardware</span>
      <p style="font-size: 0.9rem; color: var(--text-muted); line-height: 1.4;">
        A comprehensive organization scope dedicated to creating unified tools, foundational game engines, and low-level hardware abstractions.
      </p>
      <a href="#" style="display: inline-block; margin-top: 1rem; color: #fff; background: #333; padding: 4px 12px; border-radius: 4px; font-size: 0.8rem;">View Repository</a>
    </div>
  </Screen>
</Layout>
