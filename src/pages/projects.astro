---
import Layout from '../layouts/Layout.astro';
import Screen from '../components/Screen.astro';

const basePath = import.meta.env.BASE_URL;
---

<Layout title="Projects">
  <Screen>
    <div class="banner">
      <h1>Projects</h1>
    </div>
    <div class="page-content">
      <div class="ui-card">
        <img src={`${basePath}projects/camelot-banner.png`} alt="Camelot Banner" class="ui-card-banner" />
        <h2>Camelot</h2>
        <span class="ui-badge">C Framework</span>
        <span class="ui-badge">License: MPL-2.0</span>
        <p>An enterprise-grade C framework prioritizing long-term reliability, cross-platform interoperability, and transaction stability for mission-critical environments.</p>
        <a href="https://github.com/yutila-org/camelot" target="_blank" class="ui-button">View Repository</a>
      </div>
    </div>
  </Screen>
</Layout>
