---
import Layout from '../layouts/Layout.astro';
import Screen from '../components/Screen.astro';

const basePath = import.meta.env.BASE_URL;

const frameworks = [
  {
    image: `${basePath}projects/camelot-banner.png`,
    alt: "Camelot Banner",
    title: "Camelot",
    badges: ["C Framework", "License: MPL-2.0"],
    description: "An enterprise-grade C framework prioritizing long-term reliability, cross-platform interoperability, and transaction stability for mission-critical environments.",
    link: "https://github.com/yutila-org/camelot"
  }
];

const tools: { image: string; alt: string; title: string; badges: string[]; description: string; link: string; }[] = [];
---

<Layout title="Projects">
  <Screen>
    <div class="banner">
      <h1>Projects</h1>
    </div>
    <div class="page-content">


      <div class="projects-nav" style="margin-bottom: 2rem; display: flex; flex-direction: column; align-items: center; gap: 1rem;">
        <div style="display: flex; gap: 1rem;">
          <a href="#frameworks" class="ui-button" style="margin-top: 0;">Frameworks ({frameworks.length})</a>
          <a href="#tools" class="ui-button" style="margin-top: 0;">Tools & Utilities ({tools.length})</a>
        </div>
        <noscript>
          <div style="color: #ffb3ba; font-size: 0.85rem; padding: 0.5rem; border: 1px dashed #ffb3ba; border-radius: 4px; text-align: center;">
            JavaScript is disabled. Displaying all projects below.
          </div>
        </noscript>
        <div id="search-container" class="search-filter-bar" style="width: 100%; max-width: 600px; margin-bottom: 0;">
          <input type="text" id="projectSearch" class="search-input" placeholder="Search projects by name, badge, or keyword..." />
        </div>
      </div>

      <h2 id="frameworks" style="margin-top: 0; padding-top: 1rem; margin-bottom: 1.5rem;">Frameworks ({frameworks.length})</h2>
      {frameworks.length > 0 ? (
        <div class="gallery-grid">
          {frameworks.map(fw => (
            <div class="ui-card project-card" data-title={fw.title.toLowerCase()} data-badges={fw.badges.join(' ').toLowerCase()} data-desc={fw.description.toLowerCase()}>
              <img src={fw.image} alt={fw.alt} class="ui-card-banner" />
              <h2>{fw.title}</h2>
              {fw.badges.map(b => <span class="ui-badge" style="margin-right: 4px;">{b}</span>)}
              <p>{fw.description}</p>
              <a href={fw.link} target="_blank" class="ui-button">View Repository</a>
            </div>
          ))}
        </div>
      ) : (
        <p style="text-align: center; color: #888; font-style: italic;">No frameworks listed yet.</p>
      )}

      <h2 id="tools" style="padding-top: 1rem; margin-top: 2rem; margin-bottom: 1.5rem;">Tools & Utilities ({tools.length})</h2>
      {tools.length > 0 ? (
        <div class="gallery-grid">
          {tools.map(tool => (
            <div class="ui-card project-card" data-title={tool.title.toLowerCase()} data-badges={tool.badges.join(' ').toLowerCase()} data-desc={tool.description.toLowerCase()}>
              <img src={tool.image} alt={tool.alt} class="ui-card-banner" />
              <h2>{tool.title}</h2>
              {tool.badges.map(b => <span class="ui-badge" style="margin-right: 4px;">{b}</span>)}
              <p>{tool.description}</p>
              <a href={tool.link} target="_blank" class="ui-button">View Repository</a>
            </div>
          ))}
        </div>
      ) : (
        <p style="text-align: center; color: #888; font-style: italic;">More tools coming soon.</p>
      )}
    </div>
    <script>
      document.addEventListener('astro:page-load', () => {
        const searchInput = document.getElementById('projectSearch');
        const projectCards = document.querySelectorAll('.project-card');

        if (!searchInput) return;

        searchInput.addEventListener('input', (e) => {
          const target = e.target as HTMLInputElement;
          const query = target.value.toLowerCase();

          projectCards.forEach(card => {
            const title = card.getAttribute('data-title') || '';
            const badges = card.getAttribute('data-badges') || '';
            const desc = card.getAttribute('data-desc') || '';

            if (title.includes(query) || badges.includes(query) || desc.includes(query)) {
              (card as HTMLElement).style.display = '';
            } else {
              (card as HTMLElement).style.display = 'none';
            }
          });
        });
      });
    </script>
    <style>
      noscript + #search-container {
        display: none !important;
      }
    </style>
  </Screen>
</Layout>
