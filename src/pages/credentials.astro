---
import Layout from '../layouts/Layout.astro';
import Screen from '../components/Screen.astro';
---

<Layout title="Credentials">
  <Screen>
    <div class="banner">
      <h1>Credentials</h1>
    </div>
    <div class="page-content">
      <div class="gallery-grid">
        <div class="ui-card">
          <img src="https://placehold.co/800x200/151515/444444?text=System+Architectures" alt="Credential Banner" class="ui-card-banner" />
          <h2>Advanced System Architectures</h2>
          <span class="ui-badge">Certification</span>
          <p>Comprehensive certification covering concurrency, and low-level hardware interactions in modern application design.</p>
          <a href="#" class="ui-button">View Credential</a>
        </div>
        
        <div class="ui-card">
          <img src="https://placehold.co/800x200/151515/444444?text=Network+Security" alt="Network Security Banner" class="ui-card-banner" />
          <h2>Network Defense Strategies</h2>
          <span class="ui-badge">Course</span>
          <p>Deep dive into modern network defense mechanisms, zero-trust architecture, and secure protocol implementations.</p>
          <a href="#" class="ui-button">View Credential</a>
        </div>

        <div class="ui-card">
          <img src="https://placehold.co/800x200/151515/444444?text=Embedded+Systems" alt="Embedded Systems Banner" class="ui-card-banner" />
          <h2>Embedded Logic Programming</h2>
          <span class="ui-badge">Workshop</span>
          <p>Hands-on engineering workshop on writing bare-metal C and Rust for microcontrollers.</p>
          <a href="#" class="ui-button">View Credential</a>
        </div>
      </div>
    </div>
  </Screen>
</Layout>
