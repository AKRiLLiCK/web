---
import Layout from '../layouts/Layout.astro';
import Screen from '../components/Screen.astro';

const certifications = [
  {
    image: "/web/certificates/google-cybersecurity-professional.png",
    alt: "Google Cybersecurity Professional Banner",
    title: "Google Cybersecurity Professional",
    badge: "Certification",
    issuer: "Google",
    description: "Professional certificate covering network security, Linux, Python, SQL, and incident response.",
    link: "https://www.coursera.org/professional-certificates/google-cybersecurity"
  },
  {
    image: "/web/certificates/fortinet-nse123.png",
    alt: "Fortinet NSE Banner",
    title: "Fortinet NSE 1, 2 and 3",
    badge: "Certification",
    issuer: "Fortinet",
    description: "Network Security Associate certifications focusing on the threat landscape and foundational network security concepts.",
    link: "https://www.fortinet.com/nse-training"
  }
];

const courses = [
  {
    image: "/web/certificates/become-a-c-master.png",
    alt: "C Master Banner",
    title: "Become a C master (Programiz)",
    badge: "Course",
    issuer: "Programiz",
    description: "Comprehensive course on C programming, memory management, and fundamental computer science paradigms.",
    link: "https://www.programiz.com/c-programming"
  }
];
---

<Layout title="Credentials" wide={true}>
  <Screen>
    <div class="banner">
      <h1>Credentials</h1>
    </div>
    <div class="page-content">
      <div class="credentials-nav" style="margin-bottom: 2rem; text-align: center;">
        <a href="#certifications" class="ui-button" style="margin-right: 1rem;">Certifications ({certifications.length})</a>
        <a href="#courses" class="ui-button">Courses ({courses.length})</a>
      </div>

      <h2 id="certifications" style="margin-top: 0; padding-top: 1rem; margin-bottom: 1.5rem;">Certifications ({certifications.length})</h2>
      <div class="gallery-grid" style="margin-bottom: 3rem;">
        {certifications.map(cert => (
          <div class="ui-card">
            <img src={cert.image} alt={cert.alt} class="ui-card-banner" loading="lazy" />
            <h2>{cert.title}</h2>
            <div style="display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 0.5rem;">
              <span class="ui-badge">{cert.badge}</span>
              <span class="ui-badge" style="background: rgba(186,225,255,0.15); color: #bae1ff; border-color: rgba(186,225,255,0.3);">Issued by {cert.issuer}</span>
            </div>
            <p>{cert.description}</p>
            <a href={cert.link} class="ui-button" target="_blank" rel="noopener noreferrer">View Credential</a>
          </div>
        ))}
      </div>

      <h2 id="courses" style="padding-top: 1rem; margin-bottom: 1.5rem;">Courses ({courses.length})</h2>
      <div class="gallery-grid">
        {courses.map(course => (
          <div class="ui-card">
            <img src={course.image} alt={course.alt} class="ui-card-banner" loading="lazy" />
            <h2>{course.title}</h2>
            <div style="display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 0.5rem;">
              <span class="ui-badge">{course.badge}</span>
              <span class="ui-badge" style="background: rgba(186,225,255,0.15); color: #bae1ff; border-color: rgba(186,225,255,0.3);">Issued by {course.issuer}</span>
            </div>
            <p>{course.description}</p>
            <a href={course.link} class="ui-button" target="_blank" rel="noopener noreferrer">View Credential</a>
          </div>
        ))}
      </div>
    </div>
  </Screen>
</Layout>
