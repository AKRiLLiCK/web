---
import Layout from '../layouts/Layout.astro';
import Screen from '../components/Screen.astro';
---

<Layout title="Credentials">
  <Screen>
    <div class="banner">
      <h1>Credentials</h1>
    </div>
    <div class="page-content">
      <div class="ui-card">
        <img src="https://placehold.co/800x200/151515/444444?text=Credential+Banner" alt="Credential Banner" class="ui-card-banner" />
        <h2>Advanced System Architectures</h2>
        <span class="ui-badge">Certification</span>
        <p>Comprehensive certification covering advanced memory management, concurrency, and low-level hardware interactions in modern application design.</p>
        <a href="#" class="ui-button">View Credential</a>
      </div>
    </div>
  </Screen>
</Layout>
