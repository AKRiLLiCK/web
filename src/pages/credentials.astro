---
import Layout from '../layouts/Layout.astro';
import Screen from '../components/Screen.astro';
---

<Layout title="Credentials">
  <Screen>
    <div class="banner">
      <h1>Credentials</h1>
    </div>
    <div class="page-content">
      <div class="gallery-grid">
        <div class="ui-card">
          <img src="https://placehold.co/800x200/151515/444444?text=Google+Cybersecurity" alt="Google Cybersecurity Professional Banner" class="ui-card-banner" loading="lazy" />
          <h2>Google Cybersecurity Professional</h2>
          <span class="ui-badge">Certification</span>
          <p>Professional certificate covering network security, Linux, Python, SQL, and incident response.</p>
          <a href="#" class="ui-button">View Credential</a>
        </div>
        
        <div class="ui-card">
          <img src="https://placehold.co/800x200/151515/444444?text=Fortinet+NSE" alt="Fortinet NSE Banner" class="ui-card-banner" loading="lazy" />
          <h2>Fortinet NSE 1, 2 and 3</h2>
          <span class="ui-badge">Certification</span>
          <p>Network Security Associate certifications focusing on the threat landscape and foundational network security concepts.</p>
          <a href="#" class="ui-button">View Credential</a>
        </div>

        <div class="ui-card">
          <img src="https://placehold.co/800x200/151515/444444?text=C+Master" alt="C Master Banner" class="ui-card-banner" loading="lazy" />
          <h2>Become a C master (Programiz)</h2>
          <span class="ui-badge">Course</span>
          <p>Comprehensive course on C programming, memory management, and fundamental computer science paradigms.</p>
          <a href="#" class="ui-button">View Credential</a>
        </div>
      </div>
    </div>
  </Screen>
</Layout>
