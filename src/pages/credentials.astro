---
import Layout from '../layouts/Layout.astro';
import Screen from '../components/Screen.astro';
---

<Layout title="Credentials">
  <Screen>
    <div class="banner">
      <h1>Credentials</h1>
    </div>
    <div class="page-content">
      <div class="gallery-grid">
        <div class="ui-card">
          <img src="https://images.credly.com/images/0bf0f2da-a699-4c82-82e2-56dcf1f2e1c7/twitter_thumb_201604_image.png" alt="Google Cybersecurity Professional Banner" class="ui-card-banner" loading="lazy" />
          <h2>Google Cybersecurity Professional</h2>
          <span class="ui-badge">Certification</span>
          <p>Professional certificate covering network security, Linux, Python, SQL, and incident response.</p>
          <a href="https://images.credly.com/images/0bf0f2da-a699-4c82-82e2-56dcf1f2e1c7/twitter_thumb_201604_image.png" class="ui-button" target="_blank" rel="noopener noreferrer">View Credential</a>
        </div>
        
        <div class="ui-card">
          <img src="https://www.google.com/url?sa=t&source=web&rct=j&url=http%3A%2F%2Fwww.klabs.it%2Fricerca-corsi%2Fproductidn%2F2324036%2Ffortinet-nse123&ved=0CBYQjRxqFwoTCKDEyrvbgZQDFQAAAAAdAAAAABBR&opi=89978449" alt="Fortinet NSE Banner" class="ui-card-banner" loading="lazy" />
          <h2>Fortinet NSE 1, 2 and 3</h2>
          <span class="ui-badge">Certification</span>
          <p>Network Security Associate certifications focusing on the threat landscape and foundational network security concepts.</p>
          <a href="https://www.google.com/url?sa=t&source=web&rct=j&url=http%3A%2F%2Fwww.klabs.it%2Fricerca-corsi%2Fproductidn%2F2324036%2Ffortinet-nse123&ved=0CBYQjRxqFwoTCKDEyrvbgZQDFQAAAAAdAAAAABBR&opi=89978449" class="ui-button" target="_blank" rel="noopener noreferrer">View Credential</a>
        </div>

        <div class="ui-card">
          <img src="https://www.google.com/url?sa=t&source=web&rct=j&url=https%3A%2F%2Fwww.programiz.com%2F&ved=0CBYQjRxqFwoTCLjtxdPbgZQDFQAAAAAdAAAAABAG&opi=89978449" alt="C Master Banner" class="ui-card-banner" loading="lazy" />
          <h2>Become a C master (Programiz)</h2>
          <span class="ui-badge">Course</span>
          <p>Comprehensive course on C programming, memory management, and fundamental computer science paradigms.</p>
          <a href="https://www.google.com/url?sa=t&source=web&rct=j&url=https%3A%2F%2Fwww.programiz.com%2F&ved=0CBYQjRxqFwoTCLjtxdPbgZQDFQAAAAAdAAAAABAG&opi=89978449" class="ui-button" target="_blank" rel="noopener noreferrer">View Credential</a>
        </div>
      </div>
    </div>
  </Screen>
</Layout>
