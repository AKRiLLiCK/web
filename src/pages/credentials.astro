---
import Layout from '../layouts/Layout.astro';
import Screen from '../components/Screen.astro';
---

<Layout title="Credentials">
  <Screen>
    <div class="banner">
      <h1>Credentials</h1>
    </div>
    <div class="page-content">
      <div class="gallery-grid">
        <div class="ui-card">
          <img src="/web/certificates/google-cybersecurity-professional.png" alt="Google Cybersecurity Professional Banner" class="ui-card-banner" loading="lazy" />
          <h2>Google Cybersecurity Professional</h2>
          <span class="ui-badge">Certification</span>
          <p>Professional certificate covering network security, Linux, Python, SQL, and incident response.</p>
          <a href="https://www.coursera.org/professional-certificates/google-cybersecurity" class="ui-button" target="_blank" rel="noopener noreferrer">View Credential</a>
        </div>
        
        <div class="ui-card">
          <img src="/web/certificates/fortinet-nse123.png" alt="Fortinet NSE Banner" class="ui-card-banner" loading="lazy" />
          <h2>Fortinet NSE 1, 2 and 3</h2>
          <span class="ui-badge">Certification</span>
          <p>Network Security Associate certifications focusing on the threat landscape and foundational network security concepts.</p>
          <a href="https://www.fortinet.com/nse-training" class="ui-button" target="_blank" rel="noopener noreferrer">View Credential</a>
        </div>

        <div class="ui-card">
          <img src="/web/certificates/become-a-c-master.png" alt="C Master Banner" class="ui-card-banner" loading="lazy" />
          <h2>Become a C master (Programiz)</h2>
          <span class="ui-badge">Course</span>
          <p>Comprehensive course on C programming, memory management, and fundamental computer science paradigms.</p>
          <a href="https://www.programiz.com/c-programming" class="ui-button" target="_blank" rel="noopener noreferrer">View Credential</a>
        </div>
      </div>
    </div>
  </Screen>
</Layout>
