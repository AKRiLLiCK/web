---
import Layout from '../layouts/Layout.astro';
import Window from '../components/Window.astro';
---

<Layout title="Credentials">
  <header>
    <nav class="os-bevel-outset" style="padding: 0.5rem; margin-bottom: 2rem; display: flex; gap: 1rem;">
      <a href="/web/">Home</a>
      <a href="/web/projects">Projects</a>
      <a href="/web/credentials">Credentials</a>
      <a href="/web/archive">Archive</a>
    </nav>
  </header>

  <Window title="Credentials" active={true}>
    <div class="os-bevel-inset" style="padding: 1rem; min-height: 200px;">
      <ul style="list-style-type: square; padding-left: 20px; margin: 0;">
        <li style="margin-bottom: 10px;">
          <strong>Computer Engineering BSc</strong> - [In Progress]
        </li>
        <li style="margin-bottom: 10px;">
          <strong>CompTIA Security+</strong> - [Certificate]
        </li>
        <li style="margin-bottom: 10px;">
          <strong>Advanced Rust Systems</strong> - [Course]
        </li>
      </ul>
    </div>
  </Window>
</Layout>
