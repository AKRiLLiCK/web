---
import '../styles/global.css';
import Taskbar from '../components/Taskbar.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Acrilic NT Subsystem" />
  </head>
  <body>
    <div class="desktop-ui">
      <slot />
    </div>
    <Taskbar activeWindow={title} />
  </body>
</html>
