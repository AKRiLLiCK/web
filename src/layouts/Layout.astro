---
import '../styles/global.css';
import Dock from '../components/Dock.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Acrilic Portfolio" />
  </head>
  <body>
    <div class="chassis-ui">
      <!-- Top Status Bar -->
      <div class="status-bar">
        <div class="status-icons">
          <span title="Signal Strength">📶</span>
          <span title="Internet">🌐</span>
        </div>
        <div class="status-clock">
          12:00
        </div>
        <div class="status-battery">
          <span title="Battery">🔋</span>
        </div>
      </div>
      
      <!-- Content Area (Screen) -->
      <slot />

      <!-- Bottom Dock Navigation -->
      <Dock activeWindow={title} />
    </div>
  </body>
</html>
