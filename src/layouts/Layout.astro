---
import '../styles/global.css';

interface Props {
  title: string;
  lang?: string;
}

const { title, lang = 'en' } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Yutila Desktop Environment" />
  </head>
  <body>
    <div class="desktop-ui">
      <slot />
    </div>
  </body>
</html>
